rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['storeName', 'businessType', 'location', 'challenge', 'budget', 'createdAt']) &&
             data.keys().size() >= 6 &&
             data.storeName is string && data.storeName.size() <= 200 &&
             data.businessType in ['restaurant', 'massage'] &&
             data.location is string && data.location.size() <= 300 &&
             data.challenge is string && data.challenge.size() <= 2000 &&
             data.budget is string && data.budget.size() <= 100 &&
             data.createdAt == request.time;
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      // Admin should be able to read. For now, we block public reads.
      allow read: if false; 
    }
  }
}
